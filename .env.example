# GCP project + region
GCP_PROJECT_ID=project-0a83db49-ed06-47c9-be5
GCP_LOCATION=us-central1

# Cloud Storage
GCS_BUCKET=video-moments-rag-<your-suffix>
GCS_VIDEO_PREFIX=videos
GCS_OUTPUT_PREFIX=moments

# Gemini
GEMINI_MODEL=gemini-2.5-pro

# Embeddings
EMBEDDING_MODEL=text-embedding-005
EMBEDDING_DIM=768

# BigQuery vector store (created via scripts/setup_bq.py)
BQ_DATASET=moments
BQ_MOMENTS_TABLE=moments

# Local output
OUTPUT_DIR=output
